      {
        "id": "kPEsIXgg_bJVE2yi",
        "content": {
          "type": "Text",
          "format": "html",
          "text": [
            "<p><strong>ORGANIZE</strong></p><p>Think about organizing the moths into categories that will help answer your group&#x27;s research question.</p><p><strong>Would data cards or a table help you get organized?</strong></p><p>Start with the card below -- drag it across to your workspace and add the categories for data that will help with your research question. Or, to make cards from scratch, click the data card icon on the tool bar in your workspace.  </p>"
          ]
        }
      }
