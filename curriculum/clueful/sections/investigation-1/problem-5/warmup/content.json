          }
        }
      },
      {
        "id": "1kD632NtjVbI82bQ",
        "title": "Model a Speaker",
        "content": {
          "type": "Question",
          "version": 1,
          "locked": false,
          "questionId": "3xptnP",
          "tiles": [
            {
              "id": "Rm6zjtWh97H5Xo2d",
              "title": "Question Prompt",
              "fixedPosition": true,
              "content": {
                "type": "Text",
                "format": "html",
                "text": [
                  "<p>Copy this question into your workspace and draw a model of a speaker. Be sure to include the important parts and label them. Your model should help you explain how these parts work together to cause the speaker to vibrate and make sound.</p>"
                ]
              }
            },
            {
              "id": "JWBU-Ovd1WORDz_v",
              "title": "Speaker Model",
