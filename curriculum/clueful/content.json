        "emptyPlotIsNumeric": true,
        "scalePlotOnValueChange": true,
        "defaultSeriesLegend": true,
        "connectPointsByDefault": true
      },
      "drawing": {
        "tools": [
          "select",
          "line",
          "vector",
          "rectangle",
          "ellipse",
          "stamp",
