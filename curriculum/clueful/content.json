    "enableCommentRoles": [
      "student",
      "teacher",
      "researcher"
    ],
    "showCommentTag": true,
    "commentTags": {
      "exploring": "Exploring",
      "solving": "Solving",
      "applying": "Applying",
      "analyzing": "Analyzing"
    },
    "termOverrides": {
      "strategy": "Learning Journey"
    },
    "aiEvaluation": "custom",
    "aiPrompt": {
      "systemPrompt": "You are a master teacher of 7th grade STEM subjects.",
      "mainPrompt": "This is a solution from a seventh grade student in an inquiry science class. We will be evaluating the effort and techniques the student is using to allow them to reflect on the way they approach science learning.",
      "categorizationDescription": "Categorize the document according to the sophistication and solving techniques found in the document.",
      "categories": [
        "exploring",
        "solving",
        "applying",
        "analyzing"
      ],
      "keyIndicatorsPrompt": "Describe one major feature of the document work that led to the selected categorization. Use no more than 10 words.",
      "discussionPrompt": "In no more than one sentence, make one suggestion to the student in grade appropriate language for something else they can try so they get more proficient at inquiry science. Use the problems or topics in the document to motivate new exercises. This description should address the student directly as 'You'.",
      "summarizer": "text"
    },
    "showIdeasButton": true,
    "sortWorkConfig": {
      "sortOptions": [
        "Date",
        "Name",
        "Group",
        "Strategy",
        "Tools"
      ],
      "defaultPrimarySort": "Name"
    }
