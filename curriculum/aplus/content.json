    "stamps": [
      {
        "url": "cas/stamps/black-chip.png",
        "width": 25,
        "height": 25
      }
    ],
    "settings": {
      "text": {
        "tools": [
          "bold",
          "italic",
          "list-ul",
          "list-ol",
          "highlight",
          "subscript",
          "superscript",
          "link"
        ]
      },
      "table": {
        "numFormat": ".2~f",
        "tools": [
          "set-expression",
          "link-tile",
          "merge-in",
          "import-data",
          "delete"
        ]
      },
      "drawing": {
        "tools": [
          "select",
          "line",
          "vector",
          "rectangle",
          "ellipse",
          "text",
          "upload",
          "stroke-color",
          "fill-color",
          "|",
          "align",
          "rotate-right",
          "flip-horizontal",
          "flip-vertical",
          "duplicate",
          "|",
          "zoom-in",
          "zoom-out",
          "fit-all",
          "navigator",
          "delete"
        ]
      },
      "iframeInteractive": {
        "maxTiles": 1,
        "url": "https://models-resources.concord.org/hurricane-model/branch/master/index.html?topBarVisible=false&mode=storm",
        "interactiveState": {},
        "authoredState": {},
        "allowedPermissions": "geolocation; microphone; camera; bluetooth",
        "maxHeight": 0,
        "enableScroll": false
      }
    },
    "enableCommentRoles": [
      "student",
      "teacher",
      "researcher"
    ],
    "showCommentTag": true,
    "commentTags": {
      "severity": "Severity",
      "coneofuncertainty": "Cone of Uncertainty",
      "spaghetti": "Spaghetti Models",
      "landfall": "Landfall"
    },
    "aiPrompt": {
      "systemPrompt": "You are a master researcher of hurricane science.",
      "mainPrompt": "This is a discussion of a hurricane map and model made by a non-expert weather enthusiast analyzing hurricanes and speculating about their severity and path. Please evaluate the quality of the model interpretation.",
      "categorizationDescription": "Categorize the discussion in the document according to which feature of the storm is most discussed: Severity, Timing, Path, Uncertainty, or Temperature.",
      "categories": [
        "severity",
        "coneofuncertainty",
        "spaghetti",
        "landfall"
      ],
      "keyIndicatorsPrompt": "What are the key indicators in the document that support this categorization? ",
      "discussionPrompt": "In no more than 1 sentence, suggest what other kinds of modeling the document author could pursue to better understand the storm path and uncertainty.",
      "summarizer": "image"
    },
    "showIdeasButton": false,
    "sortWorkConfig": {
      "docFilterOptions": [
        "Problem",
        "All"
      ],
      "sortOptions": [
        "Date",
        "Name",
        "Strategy"
      ],
      "defaultPrimarySort": "Date"
    },
    "termOverrides": {
      "sortLabel.sortByOwner": "User",
      "strategy": "Model focus",
      "contentLevel.problem": "Model",
      "contentLevel.problems": "Storms",
      "resourcesPanel": "Models and Forcasts"
    },
    "showCommentRating": false
  },
  "sections": {
