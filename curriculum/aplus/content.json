  "config": {
    "placeholderText": "Drag text, models, or sketches here.",
    "autoAssignStudentsToIndividualGroups": true,
    "autoSectionProblemDocuments": false,
    "groupDocumentsEnabled": false,
    "defaultDocumentTitle": "Storm Name and Time",
    "defaultDocumentType": "personal",
    "defaultLearningLogDocument": false,
    "documentLabels": {
      "personal": {
        "labels": {
          "1": "Storm Analysis",
          "n": "Storm Analyses"
        }
      },
      "problem": {
        "labels": {
          "1": "Storm Analysis",
          "n": "Storm Analyses"
        }
      }
    },
    "disablePublish": [
      "student"
    ],
    "enableHistoryRoles": [
      "teacher",
      "student"
    ],
    "toolbar": [
      {
        "id": "Text",
        "title": "Text",
        "isTileTool": true
      },
      {
        "id": "IframeInteractive",
        "title": "Storm Explorer",
        "isTileTool": true
      },
      {
        "id": "Drawing",
        "title": "Sketch",
        "isTileTool": true
      },
      {
        "id": "Table",
        "title": "Table",
        "isTileTool": true
      },
      {
        "id": "duplicate",
        "title": "Duplicate Tile",
        "iconId": "icon-duplicate-tool",
        "isTileTool": false
      },
      {
        "id": "delete",
        "title": "Delete",
        "iconId": "icon-delete-tool",
        "isTileTool": false
      }
    ],
    "authorTools": [],
    "navTabs": {
      "showNavPanel": true,
      "lazyLoadTabContents": true,
      "tabSpecs": [
        {
          "tab": "class-work",
          "label": "Daily Updates",
          "sections": [
            {
              "title": "Storms 2026",
              "type": "published-problem-documents",
