          ],
          "teacherOnly": false,
          "hidden": false
        },
        {
          "tab": "sort-work",
          "label": "Model Gallery",
          "teacherOnly": false,
          "hidden": false
        },
        {
          "tab": "problems",
          "label": "User Guide",
